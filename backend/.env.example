# Option A — Checker only pastes server link (DB is created for you)
# Use your PostgreSQL server URL (with any existing DB, e.g. postgres). We create "inventory_db" and use it.
SERVER_URL="postgresql://USER:PASSWORD@HOST:PORT/postgres"

# Option B — You already created the database (e.g. in pgAdmin)
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/inventory_db?schema=public"

JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"
PORT=4000
NODE_ENV=development
