# PostgreSQL: user, password, host, port, and database name (e.g. inventory_db).
# If the database doesn't exist yet, run "npm run db:setup" and it will be created for you.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/inventory_db?schema=public"

JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"
PORT=4000
NODE_ENV=development
